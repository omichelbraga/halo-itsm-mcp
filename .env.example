# Halo ITSM MCP Server Configuration
# Copy this file to .env and fill in your values

# ===== Required =====
# Your Halo instance URL (no trailing slash)
HALO_BASE_URL=https://sanmarcosca.haloitsm.com

# ===== Transport =====
# "stdio" for Claude Desktop/Code, "http" for Docker/remote
MCP_TRANSPORT=http
# Port for HTTP mode (default: 3000)
MCP_PORT=3000

# ===== Authentication Mode =====
# "env"   - Client ID + Secret from env vars below (default)
# "oauth" - Credentials passed via Claude connector UI (only needs HALO_BASE_URL)
MCP_AUTH=oauth

# ===== Only needed when MCP_AUTH=env =====
HALO_CLIENT_ID=your_client_id_here
HALO_CLIENT_SECRET=your_client_secret_here

# ===== Optional =====
# API scope (default: all)
HALO_SCOPE=all
# Tenant name (for hosted/multi-tenant environments)
HALO_TENANT=
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
